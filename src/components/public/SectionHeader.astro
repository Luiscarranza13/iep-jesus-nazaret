---
interface Props {
  title: string;
  subtitle?: string;
  centered?: boolean;
  tag?: string;
}

const { title, subtitle, centered = true, tag } = Astro.props;
---

<div class={`mb-12 ${centered ? 'text-center' : ''}`}>
  {tag && (
    <span class="inline-flex items-center gap-2 text-primary-700 font-semibold text-sm uppercase tracking-wider mb-3">
      <span class="w-8 h-0.5 bg-primary-700 rounded-full"></span>
      {tag}
      <span class="w-8 h-0.5 bg-primary-700 rounded-full"></span>
    </span>
  )}
  <h2 class="section-title">{title}</h2>
  {subtitle && (
    <p class={`section-subtitle mt-4 text-gray-500 ${centered ? 'mx-auto' : ''}`}>
      {subtitle}
    </p>
  )}
</div>

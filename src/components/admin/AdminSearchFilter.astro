---
interface FilterOption {
  label: string;
  value: string;
}

interface Filter {
  name: string;
  label: string;
  options: FilterOption[];
}

interface Props {
  placeholder?: string;
  filters?: Filter[];
  currentValues?: Record<string, string>;
  showExport?: boolean;
  exportLabel?: string;
}

const {
  placeholder = 'Buscar...',
  filters = [],
  currentValues = {},
  showExport = false,
  exportLabel = 'Exportar CSV',
} = Astro.props;
---

<div class="flex flex-col sm:flex-row gap-3 mb-5 animate-fade-in-down">
  <!-- Búsqueda -->
  <div class="relative flex-1">
    <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
    </span>
    <input
      type="text"
      id="search-input"
      class="input pl-10 py-2.5 text-sm"
      placeholder={placeholder}
      value={currentValues.search || ''}
      autocomplete="off"
    />
    {currentValues.search && (
      <button id="clear-search" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    )}
  </div>

  <!-- Filtros -->
  {filters.map(filter => (
    <select
      name={filter.name}
      class="filter-select input py-2.5 text-sm sm:w-44 flex-shrink-0"
      data-filter={filter.name}
    >
      <option value="">{filter.label}</option>
      {filter.options.map(opt => (
        <option value={opt.value} selected={currentValues[filter.name] === opt.value}>
          {opt.label}
        </option>
      ))}
    </select>
  ))}

  <!-- Exportar CSV -->
  {showExport && (
    <button
      id="export-csv-btn"
      class="flex items-center gap-2 px-4 py-2.5 border border-gray-200 bg-white text-gray-600 text-sm font-medium rounded-xl hover:bg-gray-50 hover:border-gray-300 transition-all flex-shrink-0"
      title={exportLabel}
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
      </svg>
      <span class="hidden sm:inline">{exportLabel}</span>
    </button>
  )}
</div>

<script>
  // Búsqueda con debounce
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const clearBtn    = document.getElementById('clear-search');
  let debounceTimer: ReturnType<typeof setTimeout>;

  function applyFilters() {
    const url = new URL(window.location.href);
    const val = searchInput?.value.trim();
    if (val) url.searchParams.set('search', val);
    else url.searchParams.delete('search');
    url.searchParams.delete('page'); // reset page on filter change

    // Aplicar filtros de selects
    document.querySelectorAll<HTMLSelectElement>('.filter-select').forEach(sel => {
      const name = sel.dataset.filter!;
      if (sel.value) url.searchParams.set(name, sel.value);
      else url.searchParams.delete(name);
    });

    window.location.href = url.toString();
  }

  searchInput?.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(applyFilters, 500);
  });

  searchInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') { clearTimeout(debounceTimer); applyFilters(); }
  });

  clearBtn?.addEventListener('click', () => {
    if (searchInput) searchInput.value = '';
    applyFilters();
  });

  document.querySelectorAll<HTMLSelectElement>('.filter-select').forEach(sel => {
    sel.addEventListener('change', applyFilters);
  });

  // Exportar CSV
  document.getElementById('export-csv-btn')?.addEventListener('click', () => {
    const table = document.querySelector<HTMLTableElement>('.admin-table');
    if (!table) return;

    const rows = Array.from(table.querySelectorAll('tr'));
    const csv  = rows.map(row => {
      const cells = Array.from(row.querySelectorAll('th, td'));
      return cells
        .filter(cell => !cell.querySelector('button, a[href*="/admin"]'))
        .map(cell => `"${cell.textContent?.trim().replace(/"/g, '""') ?? ''}"`)
        .join(',');
    }).filter(row => row.replace(/,/g, '').replace(/"/g, '').trim()).join('\n');

    const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href     = url;
    a.download = `export-${new Date().toISOString().split('T')[0]}.csv`;
    a.click();
    URL.revokeObjectURL(url);
  });
</script>

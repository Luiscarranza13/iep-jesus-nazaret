---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import Icon from '../../../components/common/Icon.astro';
import { createServerClient } from '../../../lib/supabase';

const serverClient = createServerClient();
const { data: profiles } = await serverClient
  .from('profiles')
  .select('*')
  .order('created_at', { ascending: false });

const users = profiles || [];

const roleConfig: Record<string, { label: string; color: string }> = {
  admin:  { label: 'Administrador', color: 'bg-purple-100 text-purple-800' },
  editor: { label: 'Editor',        color: 'bg-blue-100 text-blue-800' },
  viewer: { label: 'Visor',         color: 'bg-gray-100 text-gray-600' },
};
---

<AdminLayout title="Usuarios" activeSection="usuarios">
  <div class="max-w-5xl mx-auto">

    <div class="flex items-center justify-between mb-6 animate-fade-in-down">
      <div>
        <h2 class="font-heading font-bold text-xl text-gray-900">Usuarios del sistema</h2>
        <p class="text-sm text-gray-500 mt-0.5">{users.length} usuario{users.length !== 1 ? 's' : ''} registrado{users.length !== 1 ? 's' : ''}</p>
      </div>
      <button id="new-user-btn" class="btn-primary gap-2 text-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
        </svg>
        Nuevo usuario
      </button>
    </div>

    <div class="card-admin overflow-hidden animate-fade-in-up">
      {users.length === 0 ? (
        <div class="text-center py-16 text-gray-400">
          <Icon name="users" class="w-12 h-12 opacity-30 mx-auto mb-3" />
          <p class="font-medium">No hay usuarios registrados</p>
        </div>
      ) : (
        <div class="overflow-x-auto">
          <table class="admin-table w-full">
            <thead>
              <tr>
                <th>Usuario</th>
                <th>Correo</th>
                <th>Rol</th>
                <th>Registrado</th>
                <th class="text-right">Acciones</th>
              </tr>
            </thead>
            <tbody>
              {users.map((u: any) => {
                const role = roleConfig[u.role] ?? roleConfig.viewer;
                const initials = (u.full_name || u.email || '?').slice(0, 2).toUpperCase();
                const date = u.created_at
                  ? new Date(u.created_at).toLocaleDateString('es-PE', { day: 'numeric', month: 'short', year: 'numeric' })
                  : '—';
                return (
                  <tr data-id={u.id}>
                    <td>
                      <div class="flex items-center gap-3">
                        <div class="w-9 h-9 bg-gradient-primary rounded-xl flex items-center justify-center text-white text-xs font-bold flex-shrink-0 overflow-hidden">
                          {u.avatar_url
                            ? <img src={u.avatar_url} alt={initials} class="w-full h-full object-cover" />
                            : initials
                          }
                        </div>
                        <span class="font-medium text-gray-900">{u.full_name || <span class="text-gray-400 italic">Sin nombre</span>}</span>
                      </div>
                    </td>
                    <td class="text-gray-500 text-sm">{u.email || '—'}</td>
                    <td><span class={`badge text-xs ${role.color}`}>{role.label}</span></td>
                    <td class="text-gray-400 text-xs">{date}</td>
                    <td>
                      <div class="flex items-center justify-end gap-1">
                        <button
                          class="edit-btn p-1.5 text-gray-400 hover:text-primary-600 hover:bg-primary-50 rounded-lg transition-colors"
                          data-id={u.id}
                          data-name={u.full_name || ''}
                          data-email={u.email || ''}
                          data-role={u.role}
                          data-avatar={u.avatar_url || ''}
                          title="Editar"
                        >
                          <Icon name="pencil" class="w-4 h-4" />
                        </button>
                        <button
                          class="delete-btn p-1.5 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors"
                          data-id={u.id}
                          data-name={u.full_name || u.email || 'este usuario'}
                          title="Eliminar"
                        >
                          <Icon name="trash-2" class="w-4 h-4" />
                        </button>
                      </div>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      )}
    </div>

    <div class="mt-5 card-admin p-4 bg-blue-50 border border-blue-100 animate-fade-in-up delay-100">
      <div class="flex gap-3 items-start">
        <Icon name="info" class="w-4 h-4 text-blue-600 flex-shrink-0 mt-0.5" />
        <p class="text-sm text-blue-800">
          <span class="font-semibold">Roles: </span>
          <span class="font-medium">Administrador</span> — acceso total ·
          <span class="font-medium">Editor</span> — crea y edita contenido ·
          <span class="font-medium">Visor</span> — solo lectura
        </p>
      </div>
    </div>
  </div>
</AdminLayout>

<!-- Modal editar usuario -->
<div id="edit-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" id="modal-backdrop"></div>
  <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-md p-6">
    <div class="flex items-center justify-between mb-5">
      <h3 class="font-heading font-bold text-lg text-gray-900">Editar usuario</h3>
      <button id="modal-close" class="p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition-colors">
        <Icon name="x" class="w-5 h-5" />
      </button>
    </div>

    <form id="edit-form" class="space-y-4">
      <input type="hidden" id="edit-id" />

      <!-- Avatar -->
      <div class="flex items-center gap-4">
        <div id="avatar-preview" class="w-16 h-16 bg-gradient-primary rounded-2xl flex items-center justify-center text-white text-xl font-bold flex-shrink-0 overflow-hidden"></div>
        <div class="flex-1">
          <p class="label mb-2">Foto de perfil</p>
          <label class="inline-flex items-center gap-2 cursor-pointer px-3 py-2 border border-gray-200 rounded-xl text-sm text-gray-600 hover:bg-gray-50 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
            </svg>
            Subir foto
            <input type="file" id="avatar-file" accept="image/png,image/jpeg,image/webp" class="hidden" />
          </label>
          <p class="text-xs text-gray-400 mt-1">PNG, JPG · Máx. 2 MB</p>
          <p id="avatar-status" class="text-xs mt-1 hidden"></p>
        </div>
      </div>

      <div>
        <label class="label" for="edit-name">Nombre completo</label>
        <input type="text" id="edit-name" class="input" placeholder="Nombre del usuario" />
      </div>

      <div>
        <label class="label" for="edit-email">Correo electrónico</label>
        <input type="email" id="edit-email" class="input bg-gray-50 cursor-not-allowed" readonly />
        <p class="text-xs text-gray-400 mt-1">El correo no se puede cambiar desde aquí</p>
      </div>

      <div>
        <label class="label" for="edit-role">Rol</label>
        <select id="edit-role" class="input">
          <option value="admin">Administrador</option>
          <option value="editor">Editor</option>
          <option value="viewer">Visor</option>
        </select>
      </div>

      <div class="flex gap-3 pt-2">
        <button type="button" id="modal-cancel"
          class="flex-1 px-4 py-2.5 border border-gray-200 text-gray-700 font-semibold rounded-xl hover:bg-gray-50 transition-colors text-sm">
          Cancelar
        </button>
        <button type="submit" id="save-btn"
          class="flex-1 btn-primary justify-center py-2.5 text-sm">
          <Icon name="save" class="w-4 h-4" />
          Guardar cambios
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  import { getSession } from '../../../lib/auth';
  import { supabase } from '../../../lib/supabase';
  import Swal from 'sweetalert2';

  getSession().then(s => { if (!s) window.location.href = '/admin/login'; });

  // ── Modal editar ──────────────────────────────────────────────────────────
  const modal         = document.getElementById('edit-modal')!;
  const editForm      = document.getElementById('edit-form') as HTMLFormElement;
  const editId        = document.getElementById('edit-id') as HTMLInputElement;
  const editName      = document.getElementById('edit-name') as HTMLInputElement;
  const editEmail     = document.getElementById('edit-email') as HTMLInputElement;
  const editRole      = document.getElementById('edit-role') as HTMLSelectElement;
  const avatarPreview = document.getElementById('avatar-preview')!;
  const avatarFile    = document.getElementById('avatar-file') as HTMLInputElement;
  const avatarStatus  = document.getElementById('avatar-status')!;

  let currentAvatarUrl = '';
  const allowedAvatarTypes = new Set(['image/png', 'image/jpeg', 'image/webp']);

  const openModal  = () => { modal.classList.remove('hidden'); modal.classList.add('flex'); };
  const closeModal = () => { modal.classList.add('hidden'); modal.classList.remove('flex'); avatarFile.value = ''; };

  document.getElementById('modal-backdrop')?.addEventListener('click', closeModal);
  document.getElementById('modal-close')?.addEventListener('click', closeModal);
  document.getElementById('modal-cancel')?.addEventListener('click', closeModal);

  // Preview local al seleccionar archivo
  avatarFile.addEventListener('change', () => {
    const file = avatarFile.files?.[0];
    if (!file) return;
    if (!allowedAvatarTypes.has(file.type)) {
      avatarStatus.textContent = 'Formato no permitido. Usa PNG, JPG o WEBP';
      avatarStatus.className = 'text-xs mt-1 text-red-600';
      avatarFile.value = '';
      return;
    }
    if (file.size > 2 * 1024 * 1024) {
      avatarStatus.textContent = 'La imagen supera los 2 MB';
      avatarStatus.className = 'text-xs mt-1 text-red-600';
      avatarFile.value = '';
      return;
    }
    avatarStatus.textContent = `Seleccionada: ${file.name}`;
    avatarStatus.className = 'text-xs mt-1 text-green-600';
    const reader = new FileReader();
    reader.onload = e => { avatarPreview.innerHTML = `<img src="${e.target?.result}" class="w-full h-full object-cover" />`; };
    reader.readAsDataURL(file);
  });

  // Abrir modal con datos del usuario
  document.querySelectorAll<HTMLElement>('.edit-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      editId.value    = btn.dataset.id!;
      editName.value  = btn.dataset.name!;
      editEmail.value = btn.dataset.email!;
      editRole.value  = btn.dataset.role!;
      currentAvatarUrl = btn.dataset.avatar || '';
      avatarStatus.className = 'text-xs mt-1 hidden';
      avatarStatus.textContent = '';

      if (currentAvatarUrl) {
        avatarPreview.innerHTML = `<img src="${currentAvatarUrl}" class="w-full h-full object-cover" />`;
      } else {
        const initials = (btn.dataset.name || btn.dataset.email || '?').slice(0, 2).toUpperCase();
        avatarPreview.innerHTML = initials;
      }
      openModal();
    });
  });

  async function uploadAvatar(file: File, userId: string) {
    const {
      data: { session },
    } = await supabase.auth.getSession();

    if (!session) {
      throw new Error('Tu sesión expiró. Vuelve a iniciar sesión.');
    }

    const ext = file.name.split('.').pop()?.toLowerCase() ?? 'jpg';
    const objectPath = `avatar-${userId}-${Date.now()}.${ext}`;

    const { error: uploadError } = await supabase.storage
      .from('blog-images')
      .upload(objectPath, file, {
        upsert: false,
        contentType: file.type,
      });

    if (uploadError) {
      throw uploadError;
    }

    const {
      data: { publicUrl },
    } = supabase.storage.from('blog-images').getPublicUrl(objectPath);

    return publicUrl;
  }

  // Guardar cambios
  editForm.addEventListener('submit', async e => {
    e.preventDefault();
    const id   = editId.value;
    const name = editName.value.trim();
    const role = editRole.value;

    (window as any).showLoading('Guardando...');

    let avatarUrl = currentAvatarUrl;
    const file = avatarFile.files?.[0];

    try {
      if (file) {
        avatarStatus.textContent = 'Subiendo foto...';
        avatarStatus.className = 'text-xs mt-1 text-gray-500';
        avatarUrl = await uploadAvatar(file, id);
      }

      const saveRes = await fetch('/api/admin/update-user', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          id,
          full_name: name || null,
          role,
          avatar_url: avatarUrl || null,
        }),
      });

      const saveData = await saveRes.json().catch(() => ({}));
      (window as any).closeLoading();

      if (!saveRes.ok) {
        (window as any).showError('Error al guardar', saveData.error ?? `HTTP ${saveRes.status}`);
      } else {
        closeModal();
        (window as any).showToast('Usuario actualizado', 'success');

        // Si el usuario editado es el usuario actual, actualizar el navbar inmediatamente
        const { data: { user } } = await supabase.auth.getUser();
        if (user && user.id === id) {
          // Actualizar avatar en el navbar sin recargar
          const navAvatar = document.getElementById('user-avatar');
          const navName   = document.getElementById('user-name');
          const navRole   = document.getElementById('user-role');

          if (navName)  navName.textContent  = name || user.email?.split('@')[0] || 'Admin';
          if (navRole) {
            const roleMap: Record<string, string> = { admin: 'Administrador', editor: 'Editor', viewer: 'Visor' };
            navRole.textContent = roleMap[role] ?? 'Administrador';
          }
          if (navAvatar && avatarUrl) {
            navAvatar.innerHTML = '';
            const img = document.createElement('img');
            img.src = avatarUrl;
            img.alt = name;
            img.className = 'w-full h-full object-cover rounded-lg';
            img.onerror = () => { navAvatar.textContent = (name || 'A')[0].toUpperCase(); };
            navAvatar.appendChild(img);
          }
        }

        setTimeout(() => location.reload(), 900);
      }
    } catch (err: any) {
      (window as any).closeLoading();
      (window as any).showError('Error al subir foto', err?.message ?? 'No se pudo subir la foto de perfil');
    }
  });

  // ── Eliminar usuario ──────────────────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.delete-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const ok = await (window as any).confirmDelete(btn.dataset.name!, 'Se eliminará el perfil del sistema.');
      if (!ok) return;
      (window as any).showLoading('Eliminando...');
      const { error } = await supabase.from('profiles').delete().eq('id', btn.dataset.id!);
      (window as any).closeLoading();
      if (error) {
        (window as any).showError('Error al eliminar', error.message);
      } else {
        (window as any).showToast('Usuario eliminado', 'success');
        document.querySelector(`tr[data-id="${btn.dataset.id}"]`)?.remove();
      }
    });
  });

  // ── Nuevo usuario ─────────────────────────────────────────────────────────
  document.getElementById('new-user-btn')?.addEventListener('click', async () => {
    const { value: vals } = await Swal.fire({
      title: 'Nuevo usuario',
      html: `
        <div style="text-align:left;display:flex;flex-direction:column;gap:12px;margin-top:8px">
          <div>
            <label style="font-size:13px;font-weight:600;color:#374151;display:block;margin-bottom:4px">Nombre completo</label>
            <input id="sw-name" class="swal2-input" placeholder="Nombre" style="margin:0;width:100%;box-sizing:border-box" />
          </div>
          <div>
            <label style="font-size:13px;font-weight:600;color:#374151;display:block;margin-bottom:4px">Correo electrónico *</label>
            <input id="sw-email" type="email" class="swal2-input" placeholder="correo@ejemplo.com" style="margin:0;width:100%;box-sizing:border-box" />
          </div>
          <div>
            <label style="font-size:13px;font-weight:600;color:#374151;display:block;margin-bottom:4px">Contraseña *</label>
            <input id="sw-pass" type="password" class="swal2-input" placeholder="Mínimo 6 caracteres" style="margin:0;width:100%;box-sizing:border-box" />
          </div>
          <div>
            <label style="font-size:13px;font-weight:600;color:#374151;display:block;margin-bottom:4px">Rol</label>
            <select id="sw-role" class="swal2-input" style="margin:0;width:100%;box-sizing:border-box;height:42px">
              <option value="editor">Editor</option>
              <option value="admin">Administrador</option>
              <option value="viewer">Visor</option>
            </select>
          </div>
        </div>`,
      showCancelButton: true,
      confirmButtonText: 'Crear usuario',
      cancelButtonText: 'Cancelar',
      customClass: { confirmButton: 'swal2-confirm', cancelButton: 'swal2-cancel' },
      buttonsStyling: false,
      preConfirm: () => {
        const email = (document.getElementById('sw-email') as HTMLInputElement).value.trim();
        const pass  = (document.getElementById('sw-pass') as HTMLInputElement).value;
        const name  = (document.getElementById('sw-name') as HTMLInputElement).value.trim();
        const role  = (document.getElementById('sw-role') as HTMLSelectElement).value;
        if (!email || !pass) { Swal.showValidationMessage('Correo y contraseña son requeridos'); return false; }
        if (pass.length < 6) { Swal.showValidationMessage('La contraseña debe tener al menos 6 caracteres'); return false; }
        return { email, pass, name, role };
      },
    });

    if (!vals) return;

    (window as any).showLoading('Creando usuario...');
    const res  = await fetch('/api/admin/create-user', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: vals.email, password: vals.pass, full_name: vals.name, role: vals.role }),
    });
    const data = await res.json();
    (window as any).closeLoading();

    if (!res.ok) {
      (window as any).showError('Error al crear usuario', data.error);
    } else {
      (window as any).showToast('Usuario creado correctamente', 'success');
      setTimeout(() => location.reload(), 900);
    }
  });
</script>

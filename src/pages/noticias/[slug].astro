---
import PublicLayout from '../../layouts/PublicLayout.astro';
import { getNewsBySlug, getNews } from '../../services/content';
import { formatDate } from '../../utils/helpers';

const { slug } = Astro.params;
const { data: news } = await getNewsBySlug(slug!);

if (!news) return Astro.redirect('/noticias');

const { data: related } = await getNews(4);
const relatedNews = related?.filter(n => n.id !== news.id).slice(0, 3) ?? [];
---

<PublicLayout
  title={news.seo_title || news.title}
  description={news.seo_description || news.summary || ''}
  image={news.image_url || undefined}
  type="article"
  publishedAt={news.published_at || undefined}
>
  <div class="bg-gradient-primary text-white py-14 sm:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      {news.type && (
        <span class="inline-block bg-white/20 text-white text-xs font-semibold px-3 py-1 rounded-full mb-4">
          {news.type}
        </span>
      )}
      {news.featured && (
        <span class="inline-block bg-yellow-400 text-yellow-900 text-xs font-bold px-3 py-1 rounded-full mb-4 ml-2">
          ⭐ Destacada
        </span>
      )}
      <h1 class="font-heading font-bold text-3xl sm:text-4xl lg:text-5xl leading-tight mb-4">
        {news.title}
      </h1>
      {news.summary && (
        <p class="text-white/80 text-lg max-w-2xl">{news.summary}</p>
      )}
      {news.published_at && (
        <p class="mt-4 text-white/60 text-sm flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          {formatDate(news.published_at)}
        </p>
      )}
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

      <article class="lg:col-span-2">
        {news.image_url && (
          <div class="rounded-2xl overflow-hidden mb-8 aspect-video">
            <img src={news.image_url} alt={news.title} class="w-full h-full object-cover" />
          </div>
        )}
        <div class="space-y-4 text-gray-700 leading-relaxed">
          {(news.content ?? '').split('\n\n').filter(Boolean).map((para: string) => (
            <p class="text-base leading-relaxed">{para}</p>
          ))}
        </div>
        <div class="mt-8 pt-6 border-t border-gray-100">
          <a href="/noticias" class="flex items-center gap-2 text-primary-700 font-semibold text-sm hover:gap-3 transition-all">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            Volver a noticias
          </a>
        </div>
      </article>

      <aside class="space-y-6">
        {relatedNews.length > 0 && (
          <div class="card p-5">
            <h3 class="font-heading font-bold text-gray-900 mb-4 text-sm uppercase tracking-wide">Más noticias</h3>
            <div class="space-y-4">
              {relatedNews.map(n => (
                <a href={`/noticias/${n.slug}`} class="block group">
                  <p class="text-sm font-semibold text-gray-800 group-hover:text-primary-700 transition-colors line-clamp-2 leading-snug">{n.title}</p>
                  {n.published_at && <p class="text-xs text-gray-400 mt-1">{formatDate(n.published_at, { month: 'short', day: 'numeric', year: 'numeric' })}</p>}
                </a>
              ))}
            </div>
          </div>
        )}
        <div class="card p-5 bg-primary-50 border border-primary-100">
          <h3 class="font-heading font-bold text-primary-900 mb-2 text-sm">I.E. Jesús de Nazaret</h3>
          <p class="text-xs text-primary-700 leading-relaxed mb-3">Bellavista, Celendín, Cajamarca · Educación secundaria pública</p>
          <a href="/contacto" class="btn-primary text-xs py-2 w-full justify-center">Contáctanos</a>
        </div>
      </aside>
    </div>
  </div>
</PublicLayout>

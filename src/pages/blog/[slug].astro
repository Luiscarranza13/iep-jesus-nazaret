---
import PublicLayout from '../../layouts/PublicLayout.astro';
import { getBlogBySlug, getBlogs } from '../../services/content';
import { formatDate } from '../../utils/helpers';

const { slug } = Astro.params;
const { data: blog } = await getBlogBySlug(slug!);

if (!blog) return Astro.redirect('/blog');

const { data: related } = await getBlogs(3);
const relatedBlogs = related?.filter(b => b.id !== blog.id).slice(0, 2) ?? [];

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://iejesusnazaret.edu.pe';
---

<PublicLayout
  title={blog.seo_title || blog.title}
  description={blog.seo_description || blog.summary || ''}
  image={blog.image_url || undefined}
  type="article"
  publishedAt={blog.published_at || undefined}
>
  <!-- Hero del artículo -->
  <div class="bg-gradient-primary text-white py-14 sm:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      {(blog as any).categories?.name && (
        <span class="inline-block bg-white/20 text-white text-xs font-semibold px-3 py-1 rounded-full mb-4">
          {(blog as any).categories.name}
        </span>
      )}
      <h1 class="font-heading font-bold text-3xl sm:text-4xl lg:text-5xl leading-tight mb-4">
        {blog.title}
      </h1>
      {blog.summary && (
        <p class="text-white/80 text-lg max-w-2xl">{blog.summary}</p>
      )}
      <div class="flex items-center gap-4 mt-6 text-white/60 text-sm">
        {blog.published_at && (
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            {formatDate(blog.published_at)}
          </span>
        )}
        <span>I.E. Jesús de Nazaret</span>
      </div>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

      <!-- Contenido principal -->
      <article class="lg:col-span-2">
        {blog.image_url && (
          <div class="rounded-2xl overflow-hidden mb-8 aspect-video">
            <img src={blog.image_url} alt={blog.title} class="w-full h-full object-cover" />
          </div>
        )}

        <div class="prose prose-gray max-w-none text-gray-700 leading-relaxed space-y-4">
          {(blog.content ?? '').split('\n\n').filter(Boolean).map((para: string) => (
            <p class="text-base leading-relaxed">{para}</p>
          ))}
        </div>

        <!-- Compartir -->
        <div class="mt-10 pt-8 border-t border-gray-100 flex items-center gap-3 flex-wrap">
          <span class="text-sm font-semibold text-gray-500">Compartir:</span>
          <a href={`https://www.facebook.com/sharer/sharer.php?u=${siteUrl}/blog/${slug}`}
             target="_blank" rel="noopener noreferrer"
             class="flex items-center gap-2 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-xl transition-colors">
            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            Facebook
          </a>
          <a href={`https://api.whatsapp.com/send?text=${encodeURIComponent(blog.title + ' ' + siteUrl + '/blog/' + slug)}`}
             target="_blank" rel="noopener noreferrer"
             class="flex items-center gap-2 px-4 py-2 bg-green-500 hover:bg-green-600 text-white text-sm font-medium rounded-xl transition-colors">
            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
        </div>
      </article>

      <!-- Sidebar -->
      <aside class="space-y-6">
        <a href="/blog" class="flex items-center gap-2 text-primary-700 font-semibold text-sm hover:gap-3 transition-all">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          Volver al blog
        </a>

        {relatedBlogs.length > 0 && (
          <div class="card p-5">
            <h3 class="font-heading font-bold text-gray-900 mb-4 text-sm uppercase tracking-wide">Más artículos</h3>
            <div class="space-y-4">
              {relatedBlogs.map(b => (
                <a href={`/blog/${b.slug}`} class="block group">
                  <p class="text-sm font-semibold text-gray-800 group-hover:text-primary-700 transition-colors line-clamp-2 leading-snug">{b.title}</p>
                  {b.published_at && <p class="text-xs text-gray-400 mt-1">{formatDate(b.published_at, { month: 'short', day: 'numeric', year: 'numeric' })}</p>}
                </a>
              ))}
            </div>
          </div>
        )}

        <div class="card p-5 bg-primary-50 border border-primary-100">
          <h3 class="font-heading font-bold text-primary-900 mb-2 text-sm">I.E. Jesús de Nazaret</h3>
          <p class="text-xs text-primary-700 leading-relaxed mb-3">Institución educativa pública · Bellavista, Celendín, Cajamarca</p>
          <a href="/contacto" class="btn-primary text-xs py-2 w-full justify-center">Contáctanos</a>
        </div>
      </aside>
    </div>
  </div>
</PublicLayout>

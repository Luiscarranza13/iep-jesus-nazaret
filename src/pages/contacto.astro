---
import PublicLayout from '../layouts/PublicLayout.astro';
import PageHero from '../components/public/PageHero.astro';
import Icon from '../components/common/Icon.astro';
import { getSettings } from '../services/settings';

const settings = await getSettings();
const whatsapp = settings.whatsapp || '';
---

<PublicLayout
  title="Contacto – I.E. Jesús de Nazaret"
  description="Contáctate con la I.E. Jesús de Nazaret en Bellavista, Celendín."
>
  <PageHero
    title="Contacto"
    subtitle="Estamos para atender tus consultas y orientarte"
    image="https://images.unsplash.com/photo-1577896851231-70ef18881754?w=1600&q=80"
  />

  <section class="py-12 sm:py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-12">

        <!-- Info -->
        <div class="space-y-4">
          <h2 class="font-heading font-bold text-xl sm:text-2xl text-gray-900">Información institucional</h2>

          <div class="card p-4 sm:p-5 flex gap-4 items-start">
            <div class="w-10 h-10 bg-primary-100 rounded-xl flex items-center justify-center flex-shrink-0">
              <Icon name="map-pin" class="w-5 h-5 text-primary-600" />
            </div>
            <div>
              <p class="font-semibold text-gray-900 text-sm">Ubicación</p>
              <p class="text-gray-600 text-sm mt-0.5">Bellavista, distrito de Celendín</p>
              <p class="text-gray-600 text-sm">Provincia de Celendín, Cajamarca</p>
            </div>
          </div>

          <div class="card p-4 sm:p-5 flex gap-4 items-start">
            <div class="w-10 h-10 bg-blue-100 rounded-xl flex items-center justify-center flex-shrink-0">
              <Icon name="school" class="w-5 h-5 text-blue-600" />
            </div>
            <div>
              <p class="font-semibold text-gray-900 text-sm">Código modular</p>
              <p class="text-gray-600 text-sm mt-0.5">0748194</p>
              <p class="text-gray-400 text-xs mt-1">Nivel: Secundaria · Gestión: Pública</p>
            </div>
          </div>

          {settings.phone && (
            <div class="card p-4 sm:p-5 flex gap-4 items-center">
              <div class="w-10 h-10 bg-green-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <Icon name="phone" class="w-5 h-5 text-green-600" />
              </div>
              <div>
                <p class="font-semibold text-gray-900 text-sm">Teléfono</p>
                <a href={`tel:${settings.phone}`} class="text-gray-600 text-sm hover:text-primary-700 transition-colors">{settings.phone}</a>
              </div>
            </div>
          )}

          {settings.facebook && (
            <a href={settings.facebook} target="_blank" rel="noopener noreferrer"
               class="flex items-center gap-3 bg-blue-600 hover:bg-blue-700 text-white font-bold px-5 py-3.5 rounded-xl transition-all shadow-lg w-full justify-center">
              <svg class="w-5 h-5 fill-current flex-shrink-0" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
              Visitar página de Facebook
            </a>
          )}

          <div class="card p-4 sm:p-5">
            <h3 class="font-semibold text-gray-900 mb-3 flex items-center gap-2 text-sm">
              <Icon name="clock" class="w-4 h-4 text-primary-600" />
              Horario de atención
            </h3>
            <div class="space-y-2.5 text-sm">
              {[
                { label: 'Turno mañana', value: '7:30 AM – 1:00 PM' },
                { label: 'Turno tarde',  value: '1:00 PM – 6:30 PM' },
              ].map(h => (
                <div class="flex justify-between items-center py-1.5 border-b border-gray-100 last:border-0">
                  <span class="text-gray-600">{h.label}</span>
                  <span class="font-semibold text-gray-900">{h.value}</span>
                </div>
              ))}
              <div class="flex justify-between items-center pt-1">
                <span class="text-gray-600">Lunes a viernes</span>
                <span class="inline-flex items-center gap-1 text-green-700 font-semibold text-xs bg-green-100 px-2 py-0.5 rounded-full">
                  <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>
                  Activo
                </span>
              </div>
            </div>
          </div>
        </div>

        <!-- Formulario WhatsApp -->
        <div class="lg:col-span-2">
          <div class="card p-6 sm:p-8">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-12 h-12 bg-green-100 rounded-2xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-green-600" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
              </div>
              <div>
                <h2 class="font-heading font-bold text-xl sm:text-2xl text-gray-900">Envíanos un mensaje</h2>
                <p class="text-gray-500 text-sm">Te responderemos por WhatsApp a la brevedad</p>
              </div>
            </div>

            <form id="contact-form" class="space-y-4">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label class="label" for="name">Nombre completo *</label>
                  <input type="text" id="name" name="name" required class="input" placeholder="Tu nombre completo" />
                </div>
                <div>
                  <label class="label" for="phone">Celular / WhatsApp</label>
                  <input type="tel" id="phone" name="phone" class="input" placeholder="999 999 999" />
                </div>
              </div>

              <div>
                <label class="label" for="subject">Asunto *</label>
                <select id="subject" name="subject" required class="input">
                  <option value="">Selecciona un asunto</option>
                  <option>Información sobre matrícula</option>
                  <option>Consulta académica</option>
                  <option>Horarios y turnos</option>
                  <option>Documentos y trámites</option>
                  <option>Información general</option>
                  <option>Otro</option>
                </select>
              </div>

              <div>
                <label class="label" for="message">Mensaje *</label>
                <textarea id="message" name="message" required rows="5" class="input resize-none"
                  placeholder="Escribe tu consulta aquí..."></textarea>
              </div>

              <button type="submit"
                class="w-full flex items-center justify-center gap-3 bg-green-500 hover:bg-green-600 active:scale-95 text-white font-bold py-4 px-6 rounded-xl transition-all shadow-lg text-base">
                <svg class="w-5 h-5 fill-current flex-shrink-0" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                Enviar por WhatsApp
              </button>

              {!whatsapp && (
                <p class="text-xs text-amber-600 bg-amber-50 border border-amber-200 rounded-lg px-3 py-2 text-center flex items-center justify-center gap-1.5">
                  <Icon name="alert-circle" class="w-3.5 h-3.5 flex-shrink-0" />
                  Configura el número de WhatsApp en el panel admin para activar esta función.
                </p>
              )}
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</PublicLayout>

<script define:vars={{ whatsapp }}>
  document.getElementById('contact-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const name    = document.getElementById('name').value.trim();
    const phone   = document.getElementById('phone').value.trim();
    const subject = document.getElementById('subject').value;
    const message = document.getElementById('message').value.trim();
    if (!name || !subject || !message) return;
    const text = [
      `*Consulta desde el sitio web - I.E. Jesús de Nazaret*`,
      ``,
      `*Nombre:* ${name}`,
      phone ? `*Celular:* ${phone}` : null,
      `*Asunto:* ${subject}`,
      ``,
      `*Mensaje:*`,
      message,
    ].filter(l => l !== null).join('\n');
    const number = (whatsapp || '').replace(/\D/g, '');
    window.open(number ? `https://wa.me/${number}?text=${encodeURIComponent(text)}` : `https://wa.me/?text=${encodeURIComponent(text)}`, '_blank');
  });
</script>

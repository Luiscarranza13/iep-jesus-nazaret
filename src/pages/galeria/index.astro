---
import PublicLayout from '../../layouts/PublicLayout.astro';
import PageHero from '../../components/public/PageHero.astro';
import { getGalleries } from '../../services/content';

const { data: galleries } = await getGalleries();

const galeriesToShow = galleries || [];
---

<PublicLayout
  title="Galería – I.E. Jesús de Nazaret"
  description="Galería fotográfica de actividades, eventos y momentos especiales de la I.E. Jesús de Nazaret en Bellavista, Celendín."
>
  <PageHero
    title="Galería"
    subtitle="Momentos y actividades de nuestra comunidad educativa"
    image="https://images.unsplash.com/photo-1523050854058-8df90110c9f1?w=1600&q=80"
  />

  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Aviso de galería vacía -->
      {galeriesToShow.length === 0 && (
        <div class="text-center py-20 text-gray-400">
          <svg class="w-16 h-16 mx-auto mb-4 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <p class="text-lg font-medium">Aún no hay galerías publicadas</p>
          <p class="text-sm mt-1">Las fotos del colegio aparecerán aquí cuando el administrador las suba</p>
        </div>
      )}

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {galeriesToShow.map((gallery: any) => (
          <a href={`/galeria/${gallery.slug}`} class="card group overflow-hidden">
            <div class="relative aspect-video overflow-hidden bg-gradient-to-br from-primary-100 to-secondary-100">
              {gallery.cover_image_url ? (
                <img
                  src={gallery.cover_image_url}
                  alt={gallery.title}
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                  loading="lazy"
                />
              ) : (
                <div class="w-full h-full flex flex-col items-center justify-center text-primary-400">
                  <svg class="w-12 h-12 mb-2 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  <p class="text-xs text-primary-500 font-medium">Fotos próximamente</p>
                </div>
              )}
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
                <p class="text-white font-semibold text-sm">Ver álbum</p>
              </div>
            </div>
            <div class="p-5">
              <h3 class="font-heading font-bold text-gray-900 text-base mb-1 group-hover:text-primary-700 transition-colors">
                {gallery.title}
              </h3>
              {gallery.description && (
                <p class="text-gray-500 text-sm line-clamp-2">{gallery.description}</p>
              )}
              <p class="text-xs text-gray-400 mt-2">
                {Array.isArray(gallery.photos) && gallery.photos[0]?.count > 0
                  ? `${gallery.photos[0].count} fotos`
                  : 'Sin fotos aún'}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</PublicLayout>

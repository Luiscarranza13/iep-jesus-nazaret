---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import Icon from '../../../components/common/Icon.astro';
import { getAdminBlogs } from '../../../services/admin-content';
import { formatDateShort } from '../../../utils/helpers';

const blogs = await getAdminBlogs().catch(() => []);
---

<AdminLayout title="Blogs" activeSection="blogs">
  <div class="flex items-center justify-between mb-6 animate-fade-in-down">
    <p class="text-gray-500 text-sm">{blogs?.length || 0} publicaciones en total</p>
    <a href="/admin/blogs/nuevo" class="btn-primary text-sm py-2.5 gap-2">
      <Icon name="plus" class="w-4 h-4" />
      Nuevo blog
    </a>
  </div>

  <div class="card-admin overflow-hidden animate-fade-in-up">
    <table class="w-full admin-table">
      <thead>
        <tr>
          <th>Título</th>
          <th class="hidden md:table-cell">Categoría</th>
          <th class="hidden sm:table-cell">Estado</th>
          <th class="hidden lg:table-cell">Fecha</th>
          <th class="text-right">Acciones</th>
        </tr>
      </thead>
      <tbody>
        {blogs && blogs.length > 0 ? blogs.map((blog, i) => (
          <tr class="animate-fade-in-up" style={`animation-delay: ${i * 40}ms`}>
            <td>
              <p class="font-semibold text-gray-900 line-clamp-1">{blog.title}</p>
              <p class="text-xs text-gray-400 mt-0.5 font-mono">/{blog.slug}</p>
            </td>
            <td class="hidden md:table-cell text-gray-500">{(blog as any).categories?.name || '—'}</td>
            <td class="hidden sm:table-cell">
              <span class={`badge ${blog.status === 'published' ? 'badge-success' : 'badge-warning'}`}>
                {blog.status === 'published' ? 'Publicado' : 'Borrador'}
              </span>
            </td>
            <td class="hidden lg:table-cell text-gray-500">
              {blog.published_at ? formatDateShort(blog.published_at) : '—'}
            </td>
            <td class="text-right">
              <div class="flex items-center justify-end gap-1">
                <a href={`/admin/blogs/${blog.id}`} class="p-2 text-primary-600 hover:bg-primary-50 rounded-lg transition-colors" title="Editar">
                  <Icon name="pencil" class="w-4 h-4" />
                </a>
                <button class="delete-btn p-2 text-red-500 hover:bg-red-50 rounded-lg transition-colors" data-id={blog.id} data-title={blog.title} title="Eliminar">
                  <Icon name="trash-2" class="w-4 h-4" />
                </button>
              </div>
            </td>
          </tr>
        )) : (
          <tr>
            <td colspan="5" class="py-20 text-center text-gray-400">
              <div class="flex flex-col items-center gap-3">
                <Icon name="file-text" class="w-12 h-12 opacity-30" />
                <p class="font-medium">No hay blogs aún</p>
                <a href="/admin/blogs/nuevo" class="btn-primary text-sm py-2">Crear primer blog</a>
              </div>
            </td>
          </tr>
        )}
      </tbody>
    </table>
  </div>
</AdminLayout>

<script>
  import { deleteBlog } from '../../../services/content';
  import { getSession } from '../../../lib/auth';

  getSession().then(s => { if (!s) window.location.href = '/admin/login'; });

  document.querySelectorAll('.delete-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id    = Number((btn as HTMLElement).dataset.id);
      const title = (btn as HTMLElement).dataset.title || '';
      if (!await (window as any).confirmDelete(title)) return;
      (window as any).showLoading('Eliminando...');
      try {
        const { error } = await deleteBlog(id);
        if (error) throw error;
        (window as any).closeLoading();
        (window as any).showToast('Blog eliminado correctamente', 'success');
        setTimeout(() => location.reload(), 1200);
      } catch (e: any) {
        (window as any).closeLoading();
        (window as any).showError('Error al eliminar', e.message);
      }
    });
  });
</script>

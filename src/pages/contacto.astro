---
import PublicLayout from '../layouts/PublicLayout.astro';
import { getSettings } from '../services/settings';

const settings = await getSettings();
---

<PublicLayout
  title="Contacto – I.E. Jesús de Nazaret"
  description="Contáctate con la I.E. Jesús de Nazaret en Bellavista, Celendín. Envíanos tu consulta sobre matrículas, horarios o actividades escolares."
>
  <!-- Encabezado -->
  <div class="bg-gradient-primary text-white py-14 sm:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-heading font-bold text-3xl sm:text-4xl lg:text-5xl mb-3 sm:mb-4">Contacto</h1>
      <p class="text-white/80 text-base sm:text-xl max-w-2xl mx-auto">
        Estamos para atender tus consultas y orientarte
      </p>
    </div>
  </div>

  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

        <!-- Información de contacto -->
        <div class="space-y-5">
          <h2 class="font-heading font-bold text-2xl text-gray-900">Información institucional</h2>

          <!-- Datos fijos -->
          <div class="card p-5 flex gap-4 items-start">
            <span class="text-2xl">📍</span>
            <div>
              <p class="font-semibold text-gray-900 text-sm">Ubicación</p>
              <p class="text-gray-600 text-sm mt-0.5">Bellavista, distrito de Celendín</p>
              <p class="text-gray-600 text-sm">Provincia de Celendín, Cajamarca</p>
            </div>
          </div>

          <div class="card p-5 flex gap-4 items-start">
            <span class="text-2xl">🏫</span>
            <div>
              <p class="font-semibold text-gray-900 text-sm">Código modular</p>
              <p class="text-gray-600 text-sm mt-0.5">0748194</p>
              <p class="text-gray-400 text-xs mt-1">Nivel: Secundaria · Gestión: Pública</p>
            </div>
          </div>

          {settings.phone && (
            <div class="card p-5 flex gap-4 items-center">
              <span class="text-2xl">📞</span>
              <div>
                <p class="font-semibold text-gray-900 text-sm">Teléfono</p>
                <a href={`tel:${settings.phone}`} class="text-gray-600 text-sm hover:text-primary-700 transition-colors">{settings.phone}</a>
              </div>
            </div>
          )}

          {settings.email && (
            <div class="card p-5 flex gap-4 items-center">
              <span class="text-2xl">✉️</span>
              <div>
                <p class="font-semibold text-gray-900 text-sm">Correo electrónico</p>
                <a href={`mailto:${settings.email}`} class="text-gray-600 text-sm hover:text-primary-700 transition-colors">{settings.email}</a>
              </div>
            </div>
          )}

          <!-- Facebook -->
          {settings.facebook && (
            <a
              href={settings.facebook}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 bg-blue-600 hover:bg-blue-700 text-white font-bold px-6 py-4 rounded-xl transition-all shadow-lg w-full justify-center"
            >
              <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
              Visitar página de Facebook
            </a>
          )}

          <!-- Horario -->
          <div class="card p-5">
            <h3 class="font-semibold text-gray-900 mb-3 flex items-center gap-2">
              <span>🕐</span> Horario de atención
            </h3>
            <div class="space-y-2 text-sm text-gray-600">
              <div class="flex justify-between">
                <span>Turno mañana</span>
                <span class="font-medium">7:30 AM – 1:00 PM</span>
              </div>
              <div class="flex justify-between">
                <span>Turno tarde</span>
                <span class="font-medium">1:00 PM – 6:30 PM</span>
              </div>
              <div class="flex justify-between">
                <span>Lunes a viernes</span>
                <span class="font-medium text-green-600">Activo</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Formulario de contacto -->
        <div class="lg:col-span-2">
          <div class="card p-8">
            <h2 class="font-heading font-bold text-2xl text-gray-900 mb-2">Envíanos un mensaje</h2>
            <p class="text-gray-500 text-sm mb-6">Completa el formulario y nos comunicaremos contigo a la brevedad posible.</p>

            <form id="contact-form" class="space-y-5">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label class="label" for="name">Nombre completo *</label>
                  <input type="text" id="name" name="name" required class="input" placeholder="Tu nombre completo" />
                </div>
                <div>
                  <label class="label" for="email">Correo electrónico *</label>
                  <input type="email" id="email" name="email" required class="input" placeholder="tu@correo.com" />
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label class="label" for="phone">Teléfono / Celular</label>
                  <input type="tel" id="phone" name="phone" class="input" placeholder="999 999 999" />
                </div>
                <div>
                  <label class="label" for="subject">Asunto *</label>
                  <select id="subject" name="subject" required class="input">
                    <option value="">Selecciona un asunto</option>
                    <option>Información sobre matrícula</option>
                    <option>Consulta académica</option>
                    <option>Horarios y turnos</option>
                    <option>Documentos y trámites</option>
                    <option>Información general</option>
                    <option>Otro</option>
                  </select>
                </div>
              </div>

              <div>
                <label class="label" for="message">Mensaje *</label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="5"
                  class="input resize-none"
                  placeholder="Escribe tu consulta o mensaje aquí..."
                ></textarea>
              </div>

              <button type="submit" id="submit-btn" class="btn-primary w-full justify-center py-4">
                <span id="btn-text">Enviar mensaje</span>
                <span id="btn-loading" class="hidden flex items-center gap-2">
                  <span class="spinner w-5 h-5"></span>
                  Enviando...
                </span>
              </button>

              <div id="form-success" class="hidden bg-green-50 border border-green-200 text-green-800 rounded-xl p-4 text-sm font-medium">
                ✓ Mensaje enviado correctamente. Nos comunicaremos contigo pronto.
              </div>
              <div id="form-error" class="hidden bg-red-50 border border-red-200 text-red-800 rounded-xl p-4 text-sm font-medium">
                ✕ Ocurrió un error al enviar. Por favor intenta nuevamente.
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</PublicLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btnText = document.getElementById('btn-text');
  const btnLoading = document.getElementById('btn-loading');
  const successMsg = document.getElementById('form-success');
  const errorMsg = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btnText?.classList.add('hidden');
    btnLoading?.classList.remove('hidden');
    successMsg?.classList.add('hidden');
    errorMsg?.classList.add('hidden');

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        successMsg?.classList.remove('hidden');
        form.reset();
      } else {
        errorMsg?.classList.remove('hidden');
      }
    } catch {
      errorMsg?.classList.remove('hidden');
    } finally {
      btnText?.classList.remove('hidden');
      btnLoading?.classList.add('hidden');
    }
  });
</script>

---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import Icon from '../../../components/common/Icon.astro';
import ImageUploader from '../../../components/admin/ImageUploader.astro';
import { supabase } from '../../../lib/supabase';

const { id } = Astro.params;
const { data: gallery } = await supabase.from('galleries').select('*, photos(id, image_url, title)').eq('id', id!).single();
if (!gallery) return Astro.redirect('/admin/galerias');
---

<AdminLayout title="Editar Galería" activeSection="galerias">
  <div class="max-w-3xl mx-auto">
    <div class="flex items-center gap-3 mb-6 animate-fade-in-down">
      <a href="/admin/galerias" class="p-2 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition-all">
        <Icon name="arrow-left" class="w-5 h-5" />
      </a>
      <h2 class="font-heading font-bold text-xl text-gray-900">Editar Galería</h2>
      <span class="ml-auto badge-gray text-xs">ID: {id}</span>
    </div>

    <!-- Datos de la galería -->
    <div class="card-admin p-6 space-y-5 animate-fade-in-up mb-6">
      <div>
        <label class="label" for="title">Título *</label>
        <input type="text" id="title" class="input" value={gallery.title} />
      </div>
      <div>
        <label class="label" for="slug">Slug</label>
        <input type="text" id="slug" class="input font-mono text-sm" value={gallery.slug} data-manual="true" />
      </div>
      <div>
        <label class="label" for="description">Descripción</label>
        <textarea id="description" rows="3" class="input resize-none">{gallery.description ?? ''}</textarea>
      </div>
      <ImageUploader fieldId="cover_image_url" bucket="gallery-images" label="Imagen de portada" currentUrl={gallery.cover_image_url ?? ''} />
      <button id="save-btn" class="btn-primary w-full justify-center py-3 gap-2">
        <Icon name="save" class="w-4 h-4" /> Guardar cambios
      </button>
    </div>

    <!-- Fotos de la galería -->
    <div class="card-admin p-6 animate-fade-in-up delay-100">
      <div class="flex items-center justify-between mb-5">
        <h3 class="font-semibold text-gray-900 flex items-center gap-2">
          <Icon name="images" class="w-5 h-5 text-primary-600" />
          Fotos ({(gallery as any).photos?.length ?? 0})
        </h3>
        <button id="add-photo-btn" class="btn-primary text-sm py-2 gap-1.5">
          <Icon name="plus" class="w-4 h-4" /> Agregar foto
        </button>
      </div>

      <!-- Uploader de fotos -->
      <div id="photo-uploader-wrap" class="hidden mb-5">
        <ImageUploader fieldId="new_photo_url" bucket="gallery-images" label="Nueva foto" />
        <div class="mt-3 flex gap-2">
          <input type="text" id="new_photo_title" class="input text-sm flex-1" placeholder="Título de la foto (opcional)" />
          <button id="confirm-photo-btn" class="btn-primary text-sm py-2 px-4 gap-1.5 flex-shrink-0">
            <Icon name="check" class="w-4 h-4" /> Agregar
          </button>
        </div>
      </div>

      <!-- Grid de fotos existentes -->
      {(gallery as any).photos?.length > 0 ? (
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3" id="photos-grid">
          {(gallery as any).photos.map((photo: any) => (
            <div class="relative group rounded-xl overflow-hidden aspect-square bg-gray-100" data-photo-id={photo.id}>
              <img src={photo.image_url} alt={photo.title ?? ''} class="w-full h-full object-cover" loading="lazy" />
              <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                <button class="delete-photo-btn p-2 bg-red-500 hover:bg-red-600 text-white rounded-lg transition-colors" data-id={photo.id}>
                  <Icon name="trash-2" class="w-4 h-4" />
                </button>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-12 text-gray-400">
          <Icon name="image" class="w-12 h-12 opacity-30 mx-auto mb-3" />
          <p class="text-sm">No hay fotos aún. Agrega la primera.</p>
        </div>
      )}
    </div>
  </div>
</AdminLayout>

<script>
  import { getSession } from '../../../lib/auth';
  import { upsertGallery } from '../../../services/content';
  import { supabase } from '../../../lib/supabase';
  import { slugify } from '../../../utils/helpers';

  getSession().then(s => { if (!s) window.location.href = '/admin/login'; });

  const id = Number(window.location.pathname.split('/').pop());
  const titleEl = document.getElementById('title') as HTMLInputElement;
  const slugEl  = document.getElementById('slug')  as HTMLInputElement;
  titleEl?.addEventListener('input', () => {
    if (!slugEl.dataset.manual) slugEl.value = slugify(titleEl.value);
  });

  // Guardar galería
  document.getElementById('save-btn')?.addEventListener('click', async () => {
    const title = titleEl?.value; const slug = slugEl?.value;
    if (!title || !slug) { (window as any).showToast('Título y slug son requeridos', 'error'); return; }
    (window as any).showLoading('Guardando...');
    try {
      const { error } = await upsertGallery({
        id, title, slug,
        description:     (document.getElementById('description') as HTMLTextAreaElement)?.value || null,
        cover_image_url: (document.getElementById('cover_image_url') as HTMLInputElement)?.value || null,
      });
      if (error) throw error;
      (window as any).closeLoading();
      (window as any).showToast('Galería actualizada ✓', 'success');
    } catch (e: any) {
      (window as any).closeLoading();
      (window as any).showError('Error al guardar', e.message);
    }
  });

  // Mostrar/ocultar uploader de fotos
  document.getElementById('add-photo-btn')?.addEventListener('click', () => {
    document.getElementById('photo-uploader-wrap')?.classList.toggle('hidden');
  });

  // Agregar foto
  document.getElementById('confirm-photo-btn')?.addEventListener('click', async () => {
    const url   = (document.getElementById('new_photo_url') as HTMLInputElement)?.value;
    const title = (document.getElementById('new_photo_title') as HTMLInputElement)?.value;
    if (!url) { (window as any).showToast('Sube una foto primero', 'error'); return; }
    (window as any).showLoading('Agregando foto...');
    try {
      const { error } = await supabase.from('photos').insert({ gallery_id: id, image_url: url, title: title || null });
      if (error) throw error;
      (window as any).closeLoading();
      (window as any).showToast('Foto agregada ✓', 'success');
      setTimeout(() => location.reload(), 800);
    } catch (e: any) {
      (window as any).closeLoading();
      (window as any).showError('Error', e.message);
    }
  });

  // Eliminar foto
  document.querySelectorAll('.delete-photo-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const photoId = Number((btn as HTMLElement).dataset.id);
      if (!await (window as any).confirmDelete('esta foto')) return;
      (window as any).showLoading('Eliminando...');
      try {
        const { error } = await supabase.from('photos').delete().eq('id', photoId);
        if (error) throw error;
        (window as any).closeLoading();
        (window as any).showToast('Foto eliminada ✓', 'success');
        (btn as HTMLElement).closest('[data-photo-id]')?.remove();
      } catch (e: any) {
        (window as any).closeLoading();
        (window as any).showError('Error', e.message);
      }
    });
  });
</script>

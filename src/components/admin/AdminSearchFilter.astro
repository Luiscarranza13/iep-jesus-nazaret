---
import Icon from './common/Icon.astro';

interface Props {
  placeholder?: string;
  filters?: {
    name: string;
    label: string;
    options: { label: string; value: string }[];
  }[];
  currentValues?: Record<string, string>;
}

const { placeholder = 'Buscar...', filters = [], currentValues = {} } = Astro.props;
---

<div class="flex flex-col md:flex-row items-center gap-4 mb-6 animate-fade-in-down">
  <!-- Buscador -->
  <div class="relative flex-1 w-full">
    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-gray-400">
      <Icon name="search" class="w-4 h-4" />
    </div>
    <input
      type="text"
      id="admin-search-input"
      class="input pl-10 h-11"
      placeholder={placeholder}
      value={currentValues.search || ''}
    />
  </div>

  <!-- Filtros -->
  <div class="flex flex-wrap items-center gap-2 w-full md:w-auto">
    {filters.map(filter => (
      <select
        data-filter={filter.name}
        class="admin-filter-select input h-11 py-0 min-w-[140px] text-sm"
      >
        <option value="">{filter.label}</option>
        {filter.options.map(opt => (
          <option value={opt.value} selected={currentValues[filter.name] === opt.value}>
            {opt.label}
          </option>
        ))}
      </select>
    ))}

    <button
      id="admin-reset-filters"
      class="p-2.5 text-gray-400 hover:text-primary-600 hover:bg-primary-50 rounded-xl transition-all"
      title="Limpiar filtros"
    >
      <Icon name="refresh-cw" class="w-5 h-5" />
    </button>
  </div>
</div>

<script>
  const searchInput = document.getElementById('admin-search-input') as HTMLInputElement;
  const selectors = document.querySelectorAll('.admin-filter-select');
  const resetBtn = document.getElementById('admin-reset-filters');

  function updateFilters() {
    const url = new URL(window.location.href);
    
    // Search
    if (searchInput.value) {
      url.searchParams.set('search', searchInput.value);
    } else {
      url.searchParams.delete('search');
    }

    // Selects
    selectors.forEach(sel => {
      const name = (sel as HTMLElement).dataset.filter!;
      const val = (sel as HTMLSelectElement).value;
      if (val) {
        url.searchParams.set(name, val);
      } else {
        url.searchParams.delete(name);
      }
    });

    // Reset pagination on filter change
    url.searchParams.set('page', '1');
    
    window.location.href = url.toString();
  }

  // Debounced search
  let timer: any;
  searchInput?.addEventListener('input', () => {
    clearTimeout(timer);
    timer = setTimeout(updateFilters, 800);
  });

  selectors.forEach(sel => {
    sel.addEventListener('change', updateFilters);
  });

  resetBtn?.addEventListener('click', () => {
    const url = new URL(window.location.href);
    url.search = '';
    window.location.href = url.pathname;
  });
</script>

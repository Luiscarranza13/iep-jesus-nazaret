---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import Icon from '../../../components/common/Icon.astro';
import { supabase } from '../../../lib/supabase';

const { data: profiles } = await supabase
  .from('profiles')
  .select('*')
  .order('created_at', { ascending: false });

const users = profiles || [];

const roleLabel: Record<string, { label: string; color: string }> = {
  admin:  { label: 'Administrador', color: 'bg-purple-100 text-purple-800' },
  editor: { label: 'Editor',        color: 'bg-blue-100 text-blue-800' },
  viewer: { label: 'Visor',         color: 'bg-gray-100 text-gray-700' },
};
---

<AdminLayout title="Usuarios" activeSection="usuarios">
  <div class="max-w-4xl mx-auto">
    <div class="flex items-center justify-between mb-6 animate-fade-in-down">
      <div>
        <h2 class="font-heading font-bold text-xl text-gray-900">Usuarios del sistema</h2>
        <p class="text-sm text-gray-500 mt-0.5">{users.length} usuario{users.length !== 1 ? 's' : ''} registrado{users.length !== 1 ? 's' : ''}</p>
      </div>
      <button id="invite-btn" class="btn-primary gap-2 text-sm">
        <Icon name="user-plus" class="w-4 h-4" />
        Invitar usuario
      </button>
    </div>

    <!-- Tabla de usuarios -->
    <div class="card-admin overflow-hidden animate-fade-in-up">
      {users.length === 0 ? (
        <div class="text-center py-16 text-gray-400">
          <Icon name="users" class="w-12 h-12 opacity-30 mx-auto mb-3" />
          <p class="font-medium">No hay usuarios registrados</p>
        </div>
      ) : (
        <table class="admin-table w-full">
          <thead>
            <tr>
              <th>Usuario</th>
              <th>Correo</th>
              <th>Rol</th>
              <th>Registrado</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            {users.map((u: any) => {
              const role = roleLabel[u.role] ?? roleLabel.viewer;
              const initials = (u.full_name || u.email || '?').slice(0, 2).toUpperCase();
              const date = u.created_at ? new Date(u.created_at).toLocaleDateString('es-PE', { day: 'numeric', month: 'short', year: 'numeric' }) : '—';
              return (
                <tr>
                  <td>
                    <div class="flex items-center gap-3">
                      <div class="w-9 h-9 bg-gradient-primary rounded-xl flex items-center justify-center text-white text-xs font-bold flex-shrink-0">
                        {u.avatar_url ? (
                          <img src={u.avatar_url} alt={initials} class="w-full h-full object-cover rounded-xl" />
                        ) : initials}
                      </div>
                      <span class="font-medium text-gray-900">{u.full_name || '—'}</span>
                    </div>
                  </td>
                  <td class="text-gray-500">{u.email || '—'}</td>
                  <td>
                    <span class={`badge text-xs ${role.color}`}>{role.label}</span>
                  </td>
                  <td class="text-gray-500 text-xs">{date}</td>
                  <td>
                    <div class="flex items-center gap-2">
                      <button
                        class="edit-role-btn p-1.5 text-gray-400 hover:text-primary-600 hover:bg-primary-50 rounded-lg transition-colors"
                        data-id={u.id}
                        data-role={u.role}
                        data-name={u.full_name || u.email}
                        title="Cambiar rol"
                      >
                        <Icon name="shield" class="w-4 h-4" />
                      </button>
                    </div>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      )}
    </div>

    <!-- Info -->
    <div class="mt-6 card-admin p-4 bg-blue-50 border border-blue-100 animate-fade-in-up delay-100">
      <div class="flex gap-3">
        <Icon name="info" class="w-5 h-5 text-blue-600 flex-shrink-0 mt-0.5" />
        <div class="text-sm text-blue-800">
          <p class="font-semibold mb-1">Roles del sistema</p>
          <ul class="space-y-1 text-blue-700">
            <li><span class="font-medium">Administrador</span> — acceso total al panel</li>
            <li><span class="font-medium">Editor</span> — puede crear y editar contenido</li>
            <li><span class="font-medium">Visor</span> — solo lectura</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  import { getSession } from '../../../lib/auth';
  import { supabase } from '../../../lib/supabase';

  getSession().then(s => { if (!s) window.location.href = '/admin/login'; });

  // Cambiar rol
  document.querySelectorAll('.edit-role-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id   = (btn as HTMLElement).dataset.id!;
      const name = (btn as HTMLElement).dataset.name!;
      const currentRole = (btn as HTMLElement).dataset.role!;

      const { value: newRole } = await (window as any).Swal?.fire({
        title: `Cambiar rol de ${name}`,
        input: 'select',
        inputOptions: { admin: 'Administrador', editor: 'Editor', viewer: 'Visor' },
        inputValue: currentRole,
        showCancelButton: true,
        confirmButtonText: 'Guardar',
        cancelButtonText: 'Cancelar',
        customClass: { confirmButton: 'swal2-confirm', cancelButton: 'swal2-cancel' },
        buttonsStyling: false,
      }) ?? {};

      if (!newRole || newRole === currentRole) return;

      (window as any).showLoading('Actualizando rol...');
      const { error } = await supabase.from('profiles').update({ role: newRole }).eq('id', id);
      (window as any).closeLoading();

      if (error) {
        (window as any).showError('Error', error.message);
      } else {
        (window as any).showToast('Rol actualizado correctamente', 'success');
        setTimeout(() => location.reload(), 1000);
      }
    });
  });

  // Invitar usuario (abre Supabase Auth)
  document.getElementById('invite-btn')?.addEventListener('click', async () => {
    const { value: email } = await (window as any).Swal?.fire({
      title: 'Invitar usuario',
      input: 'email',
      inputPlaceholder: 'correo@ejemplo.com',
      showCancelButton: true,
      confirmButtonText: 'Enviar invitación',
      cancelButtonText: 'Cancelar',
      customClass: { confirmButton: 'swal2-confirm', cancelButton: 'swal2-cancel' },
      buttonsStyling: false,
    }) ?? {};

    if (!email) return;

    (window as any).showLoading('Enviando invitación...');
    const { error } = await supabase.auth.admin?.inviteUserByEmail?.(email) ?? { error: { message: 'No disponible desde el cliente' } };
    (window as any).closeLoading();

    if (error) {
      (window as any).showError('No se pudo invitar', 'Los usuarios deben registrarse directamente en Supabase Auth o desde el dashboard de Supabase.');
    } else {
      (window as any).showToast('Invitación enviada', 'success');
    }
  });
</script>

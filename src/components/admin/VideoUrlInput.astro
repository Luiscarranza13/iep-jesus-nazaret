---
interface Props {
  fieldId: string;
  label?: string;
  currentUrl?: string;
}

const {
  fieldId,
  label = 'Video',
  currentUrl = '',
} = Astro.props;

// Detectar si hay video actual
const hasVideo = currentUrl && currentUrl.trim() !== '';
---

<div class="video-url-input space-y-2" data-field={fieldId}>
  <label class="label">{label}</label>
  <input type="hidden" id={fieldId} value={currentUrl} />

  <!-- Preview del video actual -->
  <div class={`video-preview-card ${hasVideo ? '' : 'hidden'} rounded-xl border border-blue-200 bg-blue-50`}>
    <div class="flex items-center gap-3 px-4 py-3">
      <div class="flex-shrink-0 w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
        <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
            d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
            d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <div class="flex-1 min-w-0">
        <p class="video-label text-sm font-semibold text-blue-800 truncate">Video enlazado</p>
        <a class="video-link text-xs text-blue-500 hover:text-blue-700 underline truncate block" href={currentUrl || '#'} target="_blank">
          {currentUrl || ''}
        </a>
      </div>
      <button type="button" class="video-remove-btn flex items-center gap-1.5 rounded-lg bg-red-500 px-3 py-1.5 text-xs font-semibold text-white hover:bg-red-600 transition-colors flex-shrink-0">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
        Quitar
      </button>
    </div>
  </div>

  <!-- Input de URL -->
  <div class="video-input-row flex gap-2">
    <div class="relative flex-1">
      <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </span>
      <input
        type="url"
        class="video-url-field input pl-9 py-2 text-sm"
        placeholder="https://youtube.com/watch?v=... o https://vimeo.com/..."
        value={currentUrl}
      />
    </div>
    <button
      type="button"
      class="video-apply-btn flex items-center gap-1.5 rounded-xl bg-blue-600 px-4 py-2 text-xs font-semibold text-white hover:bg-blue-700 transition-colors flex-shrink-0"
    >
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
      </svg>
      Aplicar
    </button>
  </div>
  <p class="text-xs text-gray-400">Compatible con YouTube, Vimeo y cualquier URL de video</p>
</div>

<script>
  document.querySelectorAll<HTMLElement>('.video-url-input').forEach(widget => {
    const fieldId    = widget.dataset.field!;
    const hidden     = document.getElementById(fieldId) as HTMLInputElement;
    const urlField   = widget.querySelector<HTMLInputElement>('.video-url-field')!;
    const applyBtn   = widget.querySelector<HTMLButtonElement>('.video-apply-btn')!;
    const removeBtn  = widget.querySelector<HTMLButtonElement>('.video-remove-btn');
    const previewCard = widget.querySelector<HTMLElement>('.video-preview-card')!;
    const videoLink  = widget.querySelector<HTMLAnchorElement>('.video-link')!;

    applyBtn.addEventListener('click', () => {
      const url = urlField.value.trim();
      if (!url) return;
      try { new URL(url); } catch { alert('URL no válida'); return; }
      hidden.value = url;
      hidden.dispatchEvent(new Event('input', { bubbles: true }));
      videoLink.href = url;
      videoLink.textContent = url;
      previewCard.classList.remove('hidden');
    });

    urlField.addEventListener('keydown', e => {
      if (e.key === 'Enter') { e.preventDefault(); applyBtn.click(); }
    });

    removeBtn?.addEventListener('click', () => {
      hidden.value = '';
      hidden.dispatchEvent(new Event('input', { bubbles: true }));
      urlField.value = '';
      videoLink.href = '#';
      videoLink.textContent = '';
      previewCard.classList.add('hidden');
    });
  });
</script>

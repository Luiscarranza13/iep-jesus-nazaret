---
import PublicLayout from '../layouts/PublicLayout.astro';
import PageHero from '../components/public/PageHero.astro';
import Icon from '../components/common/Icon.astro';
import { getSettings } from '../services/settings';

const settings = await getSettings();

const areas = [
  { icon: 'book-open',      area: 'Comunicación' },
  { icon: 'calculator',     area: 'Matemática' },
  { icon: 'globe',          area: 'Ciencias Sociales' },
  { icon: 'flask-conical',  area: 'Ciencia y Tecnología' },
  { icon: 'languages',      area: 'Inglés' },
  { icon: 'briefcase',      area: 'Educación para el Trabajo' },
  { icon: 'palette',        area: 'Arte y Cultura' },
  { icon: 'activity',       area: 'Educación Física' },
  { icon: 'heart',          area: 'Educación Religiosa' },
  { icon: 'user',           area: 'Desarrollo Personal' },
  { icon: 'landmark',       area: 'Formación Ciudadana' },
  { icon: 'trending-up',    area: 'Educación Económica' },
];

const enfoques = [
  { icon: 'lightbulb',      color: 'bg-yellow-100 text-yellow-700', title: 'Pensamiento crítico',       desc: 'Fomentamos la capacidad de analizar, reflexionar y tomar decisiones fundamentadas ante situaciones de la vida cotidiana.' },
  { icon: 'book-open',      color: 'bg-blue-100 text-blue-700',     title: 'Formación académica sólida', desc: 'Desarrollamos competencias en comunicación, matemáticas, ciencias y humanidades siguiendo el Currículo Nacional.' },
  { icon: 'handshake',      color: 'bg-green-100 text-green-700',   title: 'Valores y ciudadanía',       desc: 'Promovemos el respeto, la responsabilidad y la solidaridad como bases de una convivencia sana y democrática.' },
  { icon: 'target',         color: 'bg-red-100 text-red-700',       title: 'Preparación para el futuro', desc: 'Orientamos a los estudiantes hacia estudios superiores o la inserción productiva al mundo laboral.' },
  { icon: 'users',          color: 'bg-violet-100 text-violet-700', title: 'Acompañamiento docente',     desc: 'Docentes comprometidos que brindan atención personalizada gracias a los grupos reducidos de cada aula.' },
  { icon: 'sprout',         color: 'bg-emerald-100 text-emerald-700', title: 'Desarrollo personal',      desc: 'Apoyamos el crecimiento emocional, social y personal de cada estudiante durante su etapa adolescente.' },
];
---

<PublicLayout
  title="Educación Secundaria – I.E. Jesús de Nazaret"
  description="Conoce la oferta educativa de nivel secundaria de la I.E. Jesús de Nazaret en Bellavista, Celendín."
>
  <PageHero
    title="Educación Secundaria"
    subtitle="Formación integral para jóvenes de 12 a 17 años en Bellavista, Celendín"
    image="https://images.unsplash.com/photo-1580582932707-520aed937b7b?w=1600&q=80"
  />

  <!-- Descripción general -->
  <section class="py-14 sm:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <span class="inline-flex items-center gap-2 text-primary-700 font-semibold text-sm uppercase tracking-wider mb-4">
            <span class="w-8 h-0.5 bg-primary-700 rounded-full"></span>
            Nivel Secundaria
            <span class="w-8 h-0.5 bg-primary-700 rounded-full"></span>
          </span>
          <h2 class="font-heading font-bold text-2xl sm:text-3xl text-gray-900 mb-5">
            Una educación que prepara para la vida
          </h2>
          <p class="text-gray-600 leading-relaxed mb-4 text-sm sm:text-base">
            La I.E. Jesús de Nazaret ofrece educación secundaria pública y gratuita bajo la modalidad de Educación Básica Regular (EBR). Atendemos a jóvenes de 12 a 17 años del centro poblado de Bellavista y sus alrededores, en el distrito de Celendín, Cajamarca.
          </p>
          <p class="text-gray-600 leading-relaxed mb-4 text-sm sm:text-base">
            Con grupos de aproximadamente 20 estudiantes por aula, garantizamos una atención más cercana y personalizada, favoreciendo el aprendizaje y el desarrollo de cada joven.
          </p>
          <p class="text-gray-600 leading-relaxed mb-8 text-sm sm:text-base">
            Contamos con turnos de mañana y tarde para adaptarnos a las necesidades de las familias de nuestra comunidad.
          </p>

          <div class="grid grid-cols-2 gap-3">
            {[
              { icon: 'graduation-cap', label: 'Grados',       value: '1.° a 5.° de secundaria', color: 'bg-primary-50 border-primary-100 text-primary-700' },
              { icon: 'users',          label: 'Edades',        value: '12 a 17 años',             color: 'bg-blue-50 border-blue-100 text-blue-700' },
              { icon: 'clock',          label: 'Turnos',        value: 'Mañana y tarde',           color: 'bg-green-50 border-green-100 text-green-700' },
              { icon: 'user',           label: 'Alumnos/aula',  value: '~20 estudiantes',          color: 'bg-violet-50 border-violet-100 text-violet-700' },
            ].map(item => (
              <div class={`rounded-xl p-4 border ${item.color}`}>
                <div class="flex items-center gap-2 mb-1.5">
                  <Icon name={item.icon} class="w-4 h-4" />
                  <p class="text-xs font-semibold uppercase tracking-wide opacity-70">{item.label}</p>
                </div>
                <p class="font-heading font-bold text-gray-900 text-sm">{item.value}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Grados -->
        <div class="bg-gradient-to-br from-primary-600 to-primary-800 rounded-3xl p-8 sm:p-10 text-white">
          <div class="w-14 h-14 bg-white/15 rounded-2xl flex items-center justify-center mb-5">
            <Icon name="graduation-cap" class="w-7 h-7 text-white" />
          </div>
          <h3 class="font-heading font-bold text-2xl mb-1">Nivel Secundaria</h3>
          <p class="text-white/70 text-sm mb-6">Educación Básica Regular · Gestión Pública</p>
          <div class="space-y-3">
            {[
              { grado: '1.er grado', edad: '12 años' },
              { grado: '2.° grado',  edad: '13 años' },
              { grado: '3.er grado', edad: '14 años' },
              { grado: '4.° grado',  edad: '15 años' },
              { grado: '5.° grado',  edad: '16–17 años' },
            ].map(item => (
              <div class="flex items-center justify-between bg-white/10 hover:bg-white/15 transition-colors rounded-xl px-5 py-3">
                <div class="flex items-center gap-3">
                  <div class="w-2 h-2 bg-white/60 rounded-full"></div>
                  <span class="font-semibold text-white text-sm">{item.grado}</span>
                </div>
                <span class="text-white/70 text-sm">{item.edad}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Áreas curriculares -->
  <section class="py-14 sm:py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10 sm:mb-12">
        <span class="inline-flex items-center gap-2 text-primary-700 font-semibold text-sm uppercase tracking-wider mb-3">
          <span class="w-8 h-0.5 bg-primary-700 rounded-full"></span>
          Currículo Nacional
          <span class="w-8 h-0.5 bg-primary-700 rounded-full"></span>
        </span>
        <h2 class="font-heading font-bold text-2xl sm:text-3xl text-gray-900">Áreas de aprendizaje</h2>
        <p class="text-gray-500 mt-3 max-w-xl mx-auto text-sm sm:text-base">Seguimos el Currículo Nacional de Educación Básica del Ministerio de Educación del Perú</p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-4">
        {areas.map(item => (
          <div class="card p-4 sm:p-5 text-center hover:-translate-y-1 transition-transform duration-200">
            <div class="w-10 h-10 bg-primary-100 rounded-xl flex items-center justify-center mx-auto mb-3">
              <Icon name={item.icon} class="w-5 h-5 text-primary-600" />
            </div>
            <p class="font-medium text-gray-800 text-xs sm:text-sm leading-tight">{item.area}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Enfoque pedagógico -->
  <section class="py-14 sm:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10 sm:mb-12">
        <h2 class="font-heading font-bold text-2xl sm:text-3xl text-gray-900">Nuestro enfoque educativo</h2>
        <p class="text-gray-500 mt-3 max-w-xl mx-auto text-sm sm:text-base">Formamos jóvenes íntegros, críticos y preparados para los desafíos del mundo actual</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6">
        {enfoques.map(item => (
          <div class="card p-6 hover:-translate-y-1 transition-all duration-300">
            <div class={`w-12 h-12 ${item.color} rounded-2xl flex items-center justify-center mb-4`}>
              <Icon name={item.icon} class="w-6 h-6" />
            </div>
            <h3 class="font-heading font-bold text-gray-900 mb-2 text-base">{item.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-14 sm:py-20 bg-gradient-primary text-white">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="font-heading font-bold text-3xl sm:text-4xl mb-4">¿Deseas matricular a tu hijo?</h2>
      <p class="text-white/80 text-base sm:text-lg mb-8">
        Contáctanos para conocer el proceso de matrícula y los requisitos de ingreso.
      </p>
      <a href="/contacto" class="inline-flex items-center gap-2 px-8 py-4 bg-white text-primary-800 font-bold rounded-xl hover:bg-gray-50 transition-all shadow-xl">
        <Icon name="message-circle" class="w-5 h-5" />
        Solicitar información de matrícula
      </a>
    </div>
  </section>
</PublicLayout>
